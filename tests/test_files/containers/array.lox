var a = 3
var arr = array()
print(arr)
assert(arr.length() == 0)

arr.append(10)
arr.append(20)
arr.append(30)
print(arr)
assert(arr.length() == 3)

assert(arr[0] == 10)
assert(arr[1] == 20)
assert(arr[2] == 30)

arr[1] = 99
assert(arr[1] == 99)

arr.remove(99)
assert(arr.length() == 2)

arr.insert(1, 15)
assert(arr.length() == 3)
assert(arr[1] == 15)

assert(arr.index(15) == 1)

assert(arr.first() == 10)
assert(arr.last() == 30)

assert(arr.contains(15) == true)
assert(arr.contains(999) == false)

arr.reverse()
assert(arr[0] == 30)
assert(arr[1] == 15)
assert(arr[2] == 10)

var removed = arr.remove_at(1)
assert(removed == 15)
assert(arr.length() == 2)

var popped = arr.pop()
assert(popped == 10)
assert(arr.length() == 1)

arr.clear()
assert(arr.length() == 0)

var arr1 = array()
arr1.append(1)
arr1.append(2)
arr1.append(3)

var arr2 = array()
arr2.append(1)
arr2.append(2)
arr2.append(3)
assert(arr1 == arr2)

var add = arr.append
add(2)
add(3)
print(arr)
var other_arr = array()
print("arr " + arr)
print("other " + other_arr)
other_arr.appen = add
other_arr.appen(10)
print("arr " + arr)
print("other should be empty" + other_arr)
other_arr.append(1)
print(other_arr)
