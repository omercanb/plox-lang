class Hello { 
    sayit() {
        print("Heyyo")
    }
}
print("Fields")
var h = Hello()
h.hi = "HI"
h.hello = Hello()
h.hello.hi = "HELLO"
print(h.hi)
print(h.hello.hi)
h.hello.hello = Hello()

print("")
print("Basic Methods")
var b = h.sayit
b()

class Thing {
  getCallback() {

    fun localFunction() {
      print(this.name);
    }
    print(this.name)

    return localFunction;
  }
}

print("")
print("Bound Methods")
var thing = Thing()
thing.name = "HotDog"
var callback = thing.getCallback();
print(callback)
callback();

thing.name = "Soup"
callback()

class Initialized {
    init(name) {
        this.name = name
        if (name == "Burger") {
            this.name = "Hamburger"
            return
        }
        print(this.name)
    }
}

print("")
print("Initializers")
var burger = Initialized("Burger")
var pizza = Initialized("Pizza")
print(burger.name)

