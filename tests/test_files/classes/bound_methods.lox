class Person {
  sayName() {
    print(this.name)
  }
}

var jane = Person()
jane.name = "Jane"

var method = jane.sayName
method()

print("---")

var bill = Person()
bill.name = "Bill"

bill.sayName = jane.sayName
bill.sayName()

print("---")

class Egotist {
  speak() {
    print(this)
  }
}

var egotist = Egotist()
var method2 = egotist.speak
method2()
